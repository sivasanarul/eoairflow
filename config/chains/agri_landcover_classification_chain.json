{
  "dag_id": "agri_landcover_classification",
  "schedule": null,
  "max_active_runs": 1,
  "params": {
    "project": "AIRFLOW",
    "environment": "TEST",
    "service_name": "PREFIX-LC",
    "analysis_time": "20250731",
    "traindataset": "false",
    "traindataset_parcelcolumn": null,
    "foi": "yes",
    "subtiling": "yes",
    "remote_name": "SAMAS_WAW4:preprocessedeodata",
    "input_archive_roots": "/mnt/hddarchive.nfs/output",
    "output_archive_root": "/mnt/hddarchive.nfs/output",
    "output_archive_tmp": "/mnt/hddarchive.nfs/output.tmp",
    "support_data": "/mnt/ssdarchive.nfs/support_data",
    "worker_group": "classification",
    "run_no": "RUN1"
  },
  "common_volumes": [
    "/mnt/hddarchive.nfs:/mnt/hddarchive.nfs",
    "/mnt/ssdarchive.nfs:/mnt/ssdarchive.nfs",
    "/mnt/ssdarchive.nfs/support_data:/support_data",
    "/mnt/ssdarchive.nfs/support_data/classification_support_data:/classification_support_data",
    "/home/eouser/userdoc/src/tondor:/usr/local/src/tondor:ro",
    "/home/eouser/userdoc/src/cop4n2k:/usr/local/src/cop4n2k:ro",
    "/home/eouser/userdoc/src/Internal:/usr/local/src/internal:ro"
  ],
  "nodes": [
    {
      "id": "tondor_preprocessing",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 -m src.tondor.tool.preprocessing.preprocessing",
      "environment": {
        "PYTHONPATH": "/usr/local/src/tondor",
        "TONDOR_TASK_ID": "12345",
        "TONDOR_TASK_STATUS_DIR": "/var/tmp/status",
        "TONDOR_KWARGS": "{\"service_name\": \"{{ params.service_name }}\", \"environment\": \"{{ params.environment }}\", \"project\": \"{{ params.project }}\", \"analysis_time\": \"{{ params.analysis_time }}\", \"do_tiling\": \"yes\", \"do_countpix_foi\": \"no\", \"create_output\": \"no\", \"do_subtiling\": \"no\", \"subtile_count\": 1}",
        "INPUT_ARCHIVE_ROOTS": "{{ params.input_archive_roots }}",
        "OUTPUT_ARCHIVE_ROOT": "{{ params.output_archive_root }}",
        "OUTPUT_ARCHIVE_TMP": "{{ params.output_archive_tmp }}"
      },
      "network_mode": "host"
    },
    {
      "id": "submit_preprocessing",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/submit_preprocessing.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "YEARMONTH_TO": "{{ params.analysis_time.split('-')[-1] }}",
        "FOI": "{{ params.foi }}",
        "SUBTILING": "{{ params.subtiling }}",
        "TILE_NAME": null,
        "WORKER_GROUP": "{{ params.worker_group }}",
        "RUN_NO": "{{ params.run_no }}"
      },
      "network_mode": "host"
    },
    {
      "id": "wait_preprocessing_db",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/poll_db.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "JOB_LABEL": "PREPROCESS_{{ params.service_name }}_{{params.analysis_time.split('-')[-1]  }}_{{ params.environment }}",
        "TOOL_DEF": "preprocessing.json",
        "POLL_INTERVAL": "60",
        "POLL_TIMEOUT": "21600"
      },
      "network_mode": "host"
    },
    {
      "id": "submit_lc_aggregation",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/submit_cropclassification.py",
      "environment": {
        "JOB_LABEL": "AGGLC_{{ params.analysis_time.split('-')[-1] }}_{{ params.environment }}",
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "ANALYSIS_TIME": "{{ params.analysis_time.split('-')[-1] }}",
        "TRAINDATASET": "{{ params.traindataset }}",
        "TRAINDATASET_PARCELCOLUMN": "{{ params.traindataset_parcelcolumn }}",
        "REMOTE_NAME": "{{ params.remote_name }}",
        "WORKER_GROUP": "{{ params.worker_group }}",
        "RUN_NO": "{{ params.run_no }}",
        "TILE_NAME": null
      },
      "network_mode": "host"
    },
    {
      "id": "wait_lc_aggregation_db",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/poll_db.py",
      "environment": {
        "JOB_LABEL": "AGGLC_{{ params.analysis_time.split('-')[-1] }}_{{ params.environment }}",
        "TOOL_DEF": "crop_classification.json",
        "ANALYSIS_TIME": "{{ params.analysis_time.split('-')[-1] }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "TOOL_SERVICE": "{{ params.service_name }}",
        "POLL_INTERVAL": "60",
        "POLL_TIMEOUT": "21600",
        "PROJECT": "{{ params.project }}"
      },
      "network_mode": "host"
    },
    {
      "id": "crop_lc_classification",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 -m src.tondor.tool.crop_lc_classification.crop_lc_classification",
      "environment": {
        "PYTHONPATH": "/usr/local/src/tondor:/usr/local/src/internal",
        "TONDOR_TASK_ID": "12345",
        "TONDOR_TASK_STATUS_DIR": "/var/tmp/status",
        "TONDOR_KWARGS": "{\"service\": \"{{ params.service_name }}\", \"environment\": \"{{ params.environment }}\", \"project\": \"{{ params.project }}\", \"yearmonth\": \"{{ params.analysis_time.split('-')[-1]  }}\", \"remote_name\": \"{{ params.remote_name }}\", \"traindataset\": \"{{ params.traindataset }}\", \"traindataset_parcelcolumn\": \"{{ params.traindataset_parcelcolumn }}\"}",
        "INPUT_ARCHIVE_ROOTS": "{{ params.input_archive_roots }}",
        "OUTPUT_ARCHIVE_ROOT": "{{ params.output_archive_root }}",
        "OUTPUT_ARCHIVE_TMP": "{{ params.output_archive_tmp }}",
        "SUPPORT_DATA": "{{ params.support_data }}"
      },
      "network_mode": "host"
    },
    {
      "id": "merge_gpkg",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/merge_scripts/merge_gpkg.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "TIMEPERIOD": "{{ params.analysis_time }}",
        "SERVICE": "{{ params.service_name }}",
        "PRODUCT": "{{ params.service_name }}",
        "TILE_NAME": null,
        "OUTPUT_ARCHIVE_ROOT": "{{ params.output_archive_root }}",
        "PROJECT_OUTPUT_DIR": "{{ params.output_archive_root }}/projects",
        "SUPPORT_DATA": "{{ params.support_data }}"
      },
      "network_mode": "host"
    }
  ],
  "edges": [
    ["tondor_preprocessing", "submit_preprocessing"],
    ["submit_preprocessing", "wait_preprocessing_db"],
    ["wait_preprocessing_db", "submit_lc_aggregation"],
    ["submit_lc_aggregation", "wait_lc_aggregation_db"],
    ["wait_lc_aggregation_db", "crop_lc_classification"],
    ["wait_preprocessing_db", "merge_gpkg"]
  ]
}
