{
  "dag_id": "anomaly_processing_chain_json",
  "schedule": null,
  "max_active_runs": 1,
  "params": {
    "project": "SKSAMAS",
    "environment": "PROD",
    "service": "HM",
    "pixel_size": "10",
    "yearmonth": "20250630",
    "analysis_time": "20230701-20240630",
    "yearfrom": "202401",
    "yearto": "202412",
    "input_archive_roots": "/mnt/hddarchive.nfs/output",
    "output_archive_root": "/mnt/hddarchive.nfs/output",
    "output_archive_tmp": "/mnt/hddarchive.nfs/output.tmp",
    "support_data": "/mnt/ssdarchive.nfs/support_data",
    "worker_group": "ndvi",
    "run_no": "RUN1"
  },
  "common_volumes": [
    "/mnt/hddarchive.nfs:/mnt/hddarchive.nfs",
    "/mnt/ssdarchive.nfs:/mnt/ssdarchive.nfs",
    "/support_data:/support_data:ro"
  ],
  "nodes": [
    {
      "id": "ndvi_zscore",
      "type": "docker",
      "image": "optcomposite:latest",
      "command": "python3 -m tondor.tool.baresoil.ndvi_zscore",
      "environment": {
        "TONDOR_TASK_ID": "{{ task_instance.task_id }}",
        "TONDOR_KWARGS": "{\"yearmonth\": \"{{ params.yearmonth }}\", \"pixel_size\": \"{{ params.pixel_size }}\", \"project\": \"{{ params.project }}\", \"service\": \"{{ params.service }}\"}",
        "INPUT_ARCHIVE_ROOTS": "{{ params.input_archive_roots }}",
        "OUTPUT_ARCHIVE_ROOT": "{{ params.output_archive_root }}",
        "OUTPUT_ARCHIVE_TMP": "{{ params.output_archive_tmp }}"
      },
      "network_mode": "host"
    },
    {
      "id": "ndvimax_zscore",
      "type": "docker",
      "image": "optcomposite:latest",
      "command": "python3 -m tondor.tool.baresoil.ndvimax_zscore",
      "environment": {
        "TONDOR_TASK_ID": "{{ task_instance.task_id }}",
        "TONDOR_KWARGS": "{\"yearfrom\": \"{{ params.yearfrom }}\", \"yearto\": \"{{ params.yearto }}\", \"yearmonth\": \"{{ params.yearmonth }}\", \"pixel_size\": \"{{ params.pixel_size }}\", \"project\": \"{{ params.project }}\", \"environment\": \"{{ params.environment }}\", \"service\": \"{{ params.service }}\"}",
        "INPUT_ARCHIVE_ROOTS": "{{ params.input_archive_roots }}",
        "OUTPUT_ARCHIVE_ROOT": "{{ params.output_archive_root }}",
        "OUTPUT_ARCHIVE_TMP": "{{ params.output_archive_tmp }}"
      },
      "network_mode": "host"
    },
    {
      "id": "submit_anomaly",
      "type": "docker",
      "image": "cop4n2k:latest",
      "command": "python3 /app/src/gisat-internal/submit_anomaly.py",
      "environment": {
        "ANALYSIS_TIME": "{{ params.analysis_time }}",
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service }}",
        "PIXEL_SIZE": "{{ params.pixel_size }}",
        "WORKER_GROUP": "{{ params.worker_group }}",
        "RUN_NO": "{{ params.run_no }}"
      },
      "network_mode": "host"
    },
    {
      "id": "wait_db",
      "type": "db_sensor",
      "query": "SELECT COUNT(*) FROM supervisor_job AS job INNER JOIN supervisor_jobstep AS job_step ON job.id = job_step.job_id INNER JOIN supervisor_task AS task ON job_step.id = task.job_step_id WHERE job.name LIKE '%ANOMALY%' AND (task.status IS NULL OR task.status != 'K');"
    },
    {
      "id": "merge_anomaly",
      "type": "docker",
      "image": "cop4n2k:latest",
      "command": "python3 /app/src/merge_scripts/merge_anomaly.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "TIMEPERIOD": "{{ params.analysis_time }}",
        "SERVICE": "{{ params.service }}",
        "OUTPUT_ARCHIVE_ROOT": "{{ params.output_archive_root }}"
      },
      "network_mode": "host"
    }
  ],
  "edges": [
    ["ndvi_zscore", "submit_anomaly"],
    ["ndvimax_zscore", "submit_anomaly"],
    ["submit_anomaly", "wait_db"],
    ["wait_db", "merge_anomaly"]
  ]
}
