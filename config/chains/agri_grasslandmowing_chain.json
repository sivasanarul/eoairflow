{
  "dag_id": "agri_grasslandmowing_chain",
  "schedule": null,
  "max_active_runs": 1,
  "params": {
    "project": "AIRFLOW",
    "environment": "PROD",
    "service_name": "TTP",
    "pixel_size": "10",
    "analysis_time": "20250101-20250930",
    "ndvi_satellites": "sentinel-2,landsat-8,landsat-9",
    "trendfilter": "kappa",
    "parcel_column_id": "AZID",
    "foi": "no",
    "subtiling": "yes",
    "remote_name": "SAMAS_WAW4:preprocessedeodata",
    "input_archive_roots": "/mnt/hddarchive.nfs/output",
    "output_archive_root": "/mnt/hddarchive.nfs/output",
    "output_archive_tmp": "/mnt/hddarchive.nfs/output.tmp",
    "support_data": "/mnt/ssdarchive.nfs/support_data",
    "worker_group": "sar",
    "run_no": "RUN1"
  },
  "common_volumes": [
    "/mnt/hddarchive.nfs:/mnt/hddarchive.nfs",
    "/mnt/ssdarchive.nfs:/mnt/ssdarchive.nfs",
    "/mnt/ssdarchive.nfs/support_data:/support_data",
    "/mnt/ssdarchive.nfs/support_data/classification_support_data:/classification_support_data",
    "/home/eouser/userdoc/src/tondor:/usr/local/src/tondor:ro",
    "/home/eouser/userdoc/src/cop4n2k:/usr/local/src/cop4n2k:ro"
  ],
  "nodes": [
    {
      "id": "tondor_preprocessing",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 -m src.tondor.tool.preprocessing.preprocessing",
      "environment": {
        "PYTHONPATH": "/usr/local/src/tondor",
        "TONDOR_TASK_ID": "12345",
        "TONDOR_TASK_STATUS_DIR": "/var/tmp/status",
        "TONDOR_KWARGS": "{\"service_name\": \"{{ params.service_name }}\", \"environment\": \"{{ params.environment }}\", \"project\": \"{{ params.project }}\", \"analysis_time\": \"{{ params.analysis_time }}\", \"do_tiling\": \"yes\", \"do_countpix_foi\": \"no\", \"create_output\": \"no\", \"do_subtiling\": \"no\", \"subtile_count\": 1}",
        "INPUT_ARCHIVE_ROOTS": "{{ params.input_archive_roots }}",
        "OUTPUT_ARCHIVE_ROOT": "{{ params.output_archive_root }}",
        "OUTPUT_ARCHIVE_TMP": "{{ params.output_archive_tmp }}"
      },
      "network_mode": "host"
    },
    {
      "id": "submit_preprocessing",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/submit_preprocessing.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "YEARMONTH_TO": "{{ params.analysis_time.split('-')[1] }}",
        "JOB_LABEL": "PREPROCESS_{{ params.service_name }}_{{params.analysis_time.split('-')[1]  }}_{{ params.environment }}_NONSERVICENONSENTINEL",
        "FOI": "{{ params.foi }}",
        "SUBTILING": "{{ params.subtiling }}",
        "TILE_NAME": null,
        "WORKER_GROUP": "{{ params.worker_group }}",
        "RUN_NO": "{{ params.run_no }}"
      },
      "network_mode": "host"
    },
    {
      "id": "wait_preprocessing_db",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/poll_db.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "JOB_LABEL": "PREPROCESS_{{ params.service_name }}_{{params.analysis_time.split('-')[1]  }}_{{ params.environment }}_NONSERVICENONSENTINEL",
        "TOOL_DEF": "preprocessing.json",
        "POLL_INTERVAL": "60",
        "POLL_TIMEOUT": "21600"
      },
      "network_mode": "host"
    },
    {
      "id": "submit_cohstat",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/submit_cohstat.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "PIXEL_SIZE": "{{ params.pixel_size }}",
        "ANALYSIS_TIME": "{{ params.analysis_time }}",
        "REMOTE_NAME": "{{ params.remote_name }}",
        "WORKER_GROUP": "{{ params.worker_group }}",
        "RUN_NO": "{{ params.run_no }}",
        "JOB_LABEL": "{{ params.service_name }}COHSTAT_{{ params.analysis_time.split('-')[1]  }}_{{ params.environment }}_NONSERVICENONSENTINEL"
      },
      "network_mode": "host"
    },
    {
      "id": "wait_cohstat_db",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/poll_db.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ANALYSIS_TIME": "{{ params.analysis_time }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "JOB_LABEL": "{{ params.service_name }}COHSTAT_{{ params.analysis_time.split('-')[1]  }}_{{ params.environment }}_NONSERVICENONSENTINEL",
        "TOOL_DEF": "samas_statistics.json",
        "POLL_INTERVAL": "60",
        "POLL_TIMEOUT": "21600"
      },
      "network_mode": "host"
    },
    {
      "id": "submit_grasslandmowing",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/submit_grassland_mowing.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "ANALYSIS_TIME": "{{ params.analysis_time }}",
        "REMOTE_NAME": "{{ params.remote_name }}",
        "WORKER_GROUP": "{{ params.worker_group }}",
        "RUN_NO": "{{ params.run_no }}",
        "JOB_LABEL": "{{ params.service_name }}GRASSLANDMOWING_{{ params.analysis_time.split('-')[1]  }}_{{ params.environment }}"
      },
      "network_mode": "host"
    },
    {
      "id": "wait_grasslandmowing_db",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/poll_db.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ANALYSIS_TIME": "{{ params.analysis_time }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "TOOL_SERVICE": "mowing",
        "JOB_LABEL": "{{ params.service_name }}GRASSLANDMOWING_{{ params.analysis_time.split('-')[1]  }}_{{ params.environment }}",
        "TOOL_DEF": "samas_statistics.json",
        "POLL_INTERVAL": "60",
        "POLL_TIMEOUT": "21600"
      },
      "network_mode": "host"
    },
    {
      "id": "submit_ndviprofile",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/submit_ndvi_profile.py",
      "environment": {
          "JOB_LABEL": "NDVIPROFILE_{{ params.analysis_time }}_{{ params.environment }}",
          "PROJECT": "{{ params.project }}",
          "ENVIRONMENT": "{{ params.environment }}",
          "SERVICE_NAME": "{{ params.service_name }}",
          "ANALYSIS_TIME": "{{ params.analysis_time }}",
          "PARCEL_COLUMN_ID": "{{ params.parcel_column_id }}",
          "REMOTE_NAME": "{{ params.remote_name }}",
          "WORKER_GROUP": "{{ params.worker_group }}",
          "RUN_NO": "{{ params.run_no }}",
          "TILE_NAME": null,
          "SATELLITES": "{{ params.ndvi_satellites }}"
      },
      "network_mode": "host"
    },
    {
      "id": "wait_ndviprofile_db",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/poll_db.py",
      "environment": {
        "JOB_LABEL": "NDVIPROFILE_{{ params.analysis_time }}_{{ params.environment }}",
        "ANALYSIS_TIME": "{{ params.analysis_time }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "TOOL_SERVICE": "ndvi",
        "TOOL_DEF": "ndvi_profile.json",
        "POLL_INTERVAL": "60",
        "POLL_TIMEOUT": "21600",
        "PROJECT": "{{ params.project }}"
      },
      "network_mode": "host"
    },
    {
      "id": "submit_ndvitrend",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/submit_ndvi_trend.py",
      "environment": {
          "JOB_LABEL": "NDVITREND_{{ params.analysis_time }}_{{ params.environment }}",
          "PROJECT": "{{ params.project }}",
          "ENVIRONMENT": "{{ params.environment }}",
          "SERVICE_NAME": "{{ params.service_name }}",
          "ANALYSIS_TIME": "{{ params.analysis_time }}",
          "TRENDFILTER": "{{ params.trendfilter }}",
          "REMOTE_NAME": "{{ params.remote_name }}",
          "WORKER_GROUP": "{{ params.worker_group }}",
          "RUN_NO": "{{ params.run_no }}",
          "TILE_NAME": null
      },
      "network_mode": "host"
    },
    {
      "id": "wait_ndvitrend_db",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/gisat-internal/poll_db.py",
      "environment": {
        "JOB_LABEL": "NDVITREND_{{ params.analysis_time }}_{{ params.environment }}",
        "TOOL_DEF": "ndvi_profile_filtering_trend.json",
        "ANALYSIS_TIME": "{{ params.analysis_time }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "SERVICE_NAME": "{{ params.service_name }}",
        "TOOL_SERVICE": "ndvi",
        "POLL_INTERVAL": "60",
        "POLL_TIMEOUT": "21600",
        "PROJECT": "{{ params.project }}"
      },
      "network_mode": "host"
    },
    {
      "id": "merge_ndvi_trend",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/merge_scripts/merge_ndvi_trend.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "TIMEPERIOD": "{{ params.analysis_time }}",
        "SERVICE": "{{ params.service_name }}",
        "PRODUCT": "ndvi_trend",
        "TILE_NAME": null,
        "OUTPUT_ARCHIVE_ROOT": "{{ params.output_archive_root }}",
        "PROJECT_OUTPUT_DIR": "{{ params.output_archive_root }}/projects",
        "SUPPORT_DATA": "{{ params.support_data }}"
      },
      "network_mode": "host"
    },
    {
      "id": "merge_mow",
      "type": "docker",
      "image": "classification:latest",
      "command": "python3 /usr/local/src/cop4n2k/src/merge_scripts/merge_mow.py",
      "environment": {
        "PROJECT": "{{ params.project }}",
        "ENVIRONMENT": "{{ params.environment }}",
        "TIMEPERIOD": "{{ params.analysis_time }}",
        "SERVICE": "{{ params.service_name }}",
        "PRODUCT": "mowing",
        "TILE_NAME": null,
        "OUTPUT_ARCHIVE_ROOT": "{{ params.output_archive_root }}",
        "PROJECT_OUTPUT_DIR": "{{ params.output_archive_root }}/projects",
        "SUPPORT_DATA": "{{ params.support_data }}"
      },
      "network_mode": "host"
    }
  ],
  "edges": [
    ["tondor_preprocessing", "submit_preprocessing"],
    ["submit_preprocessing", "wait_preprocessing_db"],

    ["wait_preprocessing_db", "submit_cohstat"],
    ["wait_preprocessing_db", "submit_ndviprofile"],

    ["submit_cohstat", "wait_cohstat_db"],
    ["wait_cohstat_db", "submit_grasslandmowing"],
    ["submit_grasslandmowing", "wait_grasslandmowing_db"],
    ["wait_grasslandmowing_db", "merge_mow"],

    ["submit_ndviprofile", "wait_ndviprofile_db"],
     ["wait_ndviprofile_db", "submit_ndvitrend"],
    ["submit_ndvitrend", "wait_ndvitrend_db"],
    ["wait_ndvitrend_db", "merge_ndvi_trend"]    
  ]
}
